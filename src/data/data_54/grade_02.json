  "册次": [
    {
      "册": "上册",
      "古诗词": [
        {
          "标题": "小池",
          "作者": "杨万里",
          "朝代": "南宋",
          "原文": [
            "泉眼无声惜细流，",
            "树阴照水爱晴柔。",
            "小荷才露尖尖角，",
            "早有蜻蜓立上头。"
          ],
          "拼音": [
            "quán yǎn wú shēng xī xì liú，",
            "shù yīn zhào shuǐ ài qíng róu。",
            "xiǎo hé cái lù jiān jiān jiǎo，",
            "zǎo yǒu qīng tíng lì shàng tóu。"
          ],
          "注释": [
            "泉眼：泉水的出口。",
            "惜：爱惜，舍不得。",
            "细流：细小的水流。",
            "树阴：树荫。",
            "晴柔：晴天柔和的风光。",
            "尖尖角：未展开的荷叶尖端。",
            "立上头：立在荷叶的顶端。"
          ],
          "译文": "泉眼无声地珍惜细细的流水，树影照在水面上，衬托出了晴天的温柔。小荷才刚刚露出尖尖的角，早就有蜻蜓站在上头了。",
          "创作背景": "杨万里是南宋诗人。这首诗是他描写初夏景象的作品。",
          "赏析": "这首诗通过对小池、泉水、树影、小荷和蜻蜓等自然景物的描写，表现了初夏的清新气息。语言简洁而优美，是古代写景诗中的佳作。",
          "备注": "古诗篇章"
        },
        {
          "标题": "古朗月行（节选）",
          "作者": "李白",
          "朝代": "唐",
          "原文": [
            "小时不识月，",
            "呼作白玉盘。",
            "又疑瑶台镜，",
            "飞在青云端。"
          ],
          "拼音": [
            "xiǎo shí bù shí yuè，",
            "hū zuò bái yù pán。",
            "yòu yí yáo tái jìng，",
            "fēi zài qīng yún duān。"
          ],
          "注释": [
            "识：认识。",
            "呼作：称作。",
            "白玉盘：白玉做的盘子，比喻月亮圆而亮。",
            "疑：怀疑。",
            "瑶台镜：传说中神仙用的镜子。",
            "青云端：云端，天空中。"
          ],
          "译文": "小时候不认识月亮，叫它白玉盘。又怀疑是瑶台的镜子，飞在青色的云端。",
          "创作背景": "这是李白的一首童年回忆诗。",
          "赏析": "这首诗用孩童的视角看月亮，充满了童趣和想象力。虽然是用拟人和比喻的手法，但表现得非常生动。",
          "备注": "古诗篇章"
        }
      ],
      "文言文": []
    },
    {
      "册": "下册",
      "古诗词": [
        {
          "标题": "登鹳雀楼",
          "作者": "王之涣",
          "朝代": "唐",
          "原文": [
            "白日依山尽，",
            "黄河流入海。",
            "欲穷千里目，",
            "更上一层楼。"
          ],
          "拼音": [
            "bái rì yī shān jìn，",
            "huáng hé rù hǎi liú。",
            "yù qióng qiān lǐ mù，",
            "gèng shàng yī céng lóu。"
          ],
          "注释": [
            "白日：太阳。",
            "依：依傍，挨着。",
            "山：山峦。",
            "尽：落下，消失。",
            "黄河：黄河。",
            "入海：流入大海。",
            "流：流。",
            "欲：想要。",
            "穷：穷尽，达到尽头。",
            "千里目：千里之远的眼界。",
            "更：再。读gèng。",
            "上：登上。",
            "一层楼：再上一层楼。",
            "楼：高楼。"
          ],
          "译文": "太阳依着山边下落，黄河流向大海。想要看到千里外的景象，就要再上一层楼。",
          "创作背景": "王之涣是唐代诗人。这首诗是他登上鹳雀楼时创作的。",
          "赏析": "这是一首表现进取精神的诗。虽然只有四句，但通过对壮阔景象的描写和对上进精神的暗示，表现了诗人的豪气。最后两句成为了表现进取精神的名句。",
          "备注": "古诗篇章"
        }
      ],
      "文言文": []
    }
  ]
